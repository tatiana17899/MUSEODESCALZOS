@using Microsoft.AspNetCore.Identity
@using MuseoDescalzos.Models
@inject SignInManager<Usuario> SignInManager
@inject UserManager<Usuario> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var usuario = await UserManager.GetUserAsync(User);
    <li class="nav-item dropdown">
        <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <img src="@usuario.Rutalmagen" alt="Perfil" width="30" height="30" class="rounded-circle me-2">
            Hello @User.Identity?.Name!
        </a>
        <ul class="dropdown-menu" aria-labelledby="navbarDropdown">
            <li><a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">Perfil</a></li>
            <li><form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="dropdown-item">Cerrar Sesión</button>
            </form></li>
        </ul>
    </li>
}
else
{
    <li class="nav-item">
        <form class="d-flex">
            <button class="btn btn-log mx-2" id="login" asp-area="Identity" asp-page="/Account/Login">
                Iniciar Sesion
            </button>
            <button class="btn btn-reg mx-2" id="register" asp-area="Identity" asp-page="/Account/Register">
                Registrarse
            </button>
        </form>
    </li>
}